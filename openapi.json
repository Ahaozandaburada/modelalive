  "components": {
    "schemas": {
      "BatchRequest": {
        "properties": {
          "models": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "maxItems": 100,
            "minItems": 1,
            "title": "Models"
          }
        },
        "type": "object",
        "required": [
          "models"
        ],
        "title": "BatchRequest"
      },
      "CheckoutRequest": {
        "properties": {
          "email": {
            "type": "string",
            "maxLength": 320,
            "minLength": 3,
            "title": "Email"
          },
          "plan": {
            "type": "string",
            "pattern": "^pro$",
            "title": "Plan",
            "default": "pro"
          }
        },
        "type": "object",
        "required": [
          "email"
        ],
        "title": "CheckoutRequest"
      },
      "EnsureRequest": {
        "properties": {
          "model": {
            "type": "string",
            "maxLength": 256,
            "minLength": 1,
            "title": "Model"
          },
          "warn_deprecated": {
            "anyOf": [
              {
                "type": "boolean"
              },
              {
                "type": "null"
              }
            ],
            "title": "Warn Deprecated"
          },
          "strict_unknown": {
            "anyOf": [
              {
                "type": "boolean"
              },
              {
                "type": "null"
              }
            ],
            "title": "Strict Unknown"
          }
        },
        "type": "object",
        "required": [
          "model"
        ],
        "title": "EnsureRequest"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "ValidationError": {
        "properties": {
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "type": "array",
            "title": "Location"
          },
          "msg": {
            "type": "string",
            "title": "Message"
          },
          "type": {
            "type": "string",
            "title": "Error Type"
          },
          "input": {
            "title": "Input"
          },
          "ctx": {
            "type": "object",
            "title": "Context"
          }
        },
        "type": "object",
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError"
      }
    }
