{
  "name": "modelalive",
  "version": "1.6.1",
  "description": "Universal LLM pre-flight gate — Alive (lifecycle) + Stable (behavioral drift) before every inference call.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist", "registry.json", "stable_prompts.json"],
  "scripts": {
    "build": "tsc && cp ../registry/models.json registry.json && cp ../modelalive/data/stable_prompts.json stable_prompts.json",
    "prebuild": "cp ../registry/models.json registry.json && cp ../modelalive/data/stable_prompts.json stable_prompts.json",
    "test": "npm run build && node --test dist/smoke.test.js dist/parity.test.js dist/stable.test.js"
  },
  "keywords": ["llm", "anthropic", "openai", "gemini", "deprecation", "model-id", "stable", "drift", "openrouter"],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Ahaozandaburada/modelalive.git",
    "directory": "js"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.0"
  }
}
