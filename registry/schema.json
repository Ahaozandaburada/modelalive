{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ModelAlive registry",
  "type": "object",
  "required": ["version", "schema_version", "sources", "models"],
  "properties": {
    "version": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
    "schema_version": { "type": "integer", "minimum": 2 },
    "sources": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["url", "checked_at"],
        "properties": {
          "url": { "type": "string", "format": "uri" },
          "checked_at": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" }
        }
      }
    },
    "aliases": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "models": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/model" }
    }
  },
  "$defs": {
    "model": {
      "type": "object",
      "required": ["provider", "status", "source"],
      "properties": {
        "provider": { "type": "string" },
        "status": { "enum": ["active", "deprecated", "retired", "legacy"] },
        "deprecated_at": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
        "retired_at": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
        "replacement": { "type": ["string", "null"] },
        "breaking_changes": { "type": "array", "items": { "type": "string" } },
        "migrate_url": { "type": "string", "format": "uri" },
        "source": { "type": "string" },
        "notes": { "type": "string" }
      }
    }
  }
}
